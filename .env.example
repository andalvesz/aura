# Supabase — Project Settings → API
# Use SOMENTE as variáveis NEXT_PUBLIC_* no app (browser + server).
# Não defina SUPABASE_URL / SUPABASE_ANON_KEY com valores diferentes.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Site URL (Vercel: https://seu-app.vercel.app | local: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — recursos de IA (Aura Central, Travel, English Coach, Follow-up, Social…)
OPENAI_API_KEY=

# Google Calendar + Gmail — Google Cloud Console → APIs & Services → Credentials (OAuth 2.0)
# Redirect URI autorizado: {NEXT_PUBLIC_SITE_URL}/api/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional (padrão: {NEXT_PUBLIC_SITE_URL}/api/google-calendar/callback)
# GOOGLE_REDIRECT_URI=
# Gmail (Centro de Comunicação — padrão: {NEXT_PUBLIC_SITE_URL}/api/gmail/callback)
# GMAIL_REDIRECT_URI=
# Google Drive (Knowledge Sources — padrão: {NEXT_PUBLIC_SITE_URL}/api/knowledge-sources/google/callback)
# GOOGLE_DRIVE_REDIRECT_URI=
# Google Drive (Expert Brain — padrão: {NEXT_PUBLIC_SITE_URL}/api/google-drive/callback)
# GOOGLE_DRIVE_EXPERT_REDIRECT_URI=

# Chave de 32 bytes em hex ou base64 para criptografar credenciais de plataformas.
PLATFORM_CREDENTIALS_KEY=

# Expert Brain — segredo para o worker automático (Vercel Cron / chamadas internas).
# Quando definido, o Vercel Cron envia "Authorization: Bearer $CRON_SECRET"
# automaticamente para /api/expert-brain-queue. Ver vercel.json (schedule */10 min).
# Observação: a fila é escopada por usuário (sessão Supabase); o cron autoriza o
# chamador, mas o processamento unattended multiusuário exigiria um worker com
# service-role (fora do escopo desta fase beta).
CRON_SECRET=

# Meta Business — Meta for Developers → App → Settings → Basic
# Produto: Marketing API + Facebook Login
# Redirect URI autorizado: {NEXT_PUBLIC_SITE_URL}/api/meta/callback
# Permissões OAuth: ads_read, ads_management, business_management,
# pages_read_engagement, pages_show_list, read_insights
META_APP_ID=
META_APP_SECRET=
# Opcional (padrão: {NEXT_PUBLIC_SITE_URL}/api/meta/callback)
# META_REDIRECT_URI=
